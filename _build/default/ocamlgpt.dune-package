(lang dune 3.21)
(name ocamlgpt)
(sections (lib .) (libexec .) (bin ../../bin) (doc ../../doc/ocamlgpt))
(files
 (lib
  (META
   dune-package
   lib/microgpt.a
   lib/microgpt.cma
   lib/microgpt.cmi
   lib/microgpt.cmt
   lib/microgpt.cmx
   lib/microgpt.cmxa
   lib/microgpt.ml
   opam))
 (libexec (lib/microgpt.cmxs))
 (bin (ocamlgpt))
 (doc (README.md)))
(library
 (name ocamlgpt.lib)
 (kind normal)
 (archives (byte lib/microgpt.cma) (native lib/microgpt.cmxa))
 (plugins (byte lib/microgpt.cma) (native lib/microgpt.cmxs))
 (native_archives lib/microgpt.a)
 (main_module_name Microgpt)
 (modes byte native)
 (modules
  (singleton
   (obj_name microgpt)
   (visibility public)
   (source (path Microgpt) (impl (path lib/microgpt.ml))))))
